# =============================================================================
# OrgOS — Backend Environment Variables
# cp .env.example .env  →  fill in every [REQUIRED] value  →  never commit .env
# =============================================================================

# Entra ID — Azure Portal → Entra ID → App registrations → OrgOS
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here
AI_REVIEW_QUEUE_LIST_ID=your-ai-review-queue-list-id-here
DOCUMENT_LIFECYCLE_LIST_ID=your-document-lifecycle-list-id-here
CONTROL_REGISTER_LIST_ID=your-control-register-list-id-here
EVIDENCE_TRACKER_LIST_ID=your-evidence-tracker-list-id-here
AUDIT_LOG_LIST_ID=your-audit-log-list-id-here
STRATEGIC_RISK_REGISTER_LIST_ID=your-strategic-risk-register-list-id-here
GAP_ANALYSIS_LIST_ID=your-gap-analysis-list-id-here
# SharePoint — GET https://graph.microsoft.com/v1.0/sites/dragnet.sharepoint.com:/sites/orgos
SHAREPOINT_SITE_ID=your-site-id-here
SHAREPOINT_SITE_URL=https://dragnetnigeria.sharepoint.com/sites/orgos
COMPLIANCE_SITE_URL=https://dragnetnigeria.sharepoint.com/sites/compliance
COMPLIANCE_LIBRARY_NAME=Documents
COMPLIANCE_STARTING_FOLDER=GRC MASTERY

# SharePoint List IDs — leave as "placeholder" until lists are created in SharePoint
DOCUMENT_REGISTER_LIST_ID=placeholder
ROLE_REGISTER_LIST_ID=placeholder
COMPLIANCE_CALENDAR_LIST_ID=placeholder
CONTRACT_REGISTER_LIST_ID=placeholder


# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173
APP_PORT=8000
LOG_LEVEL=DEBUG
SKIP_AUTH=false

# LLM provider — set to "runpod" to use RunPod serverless, or "ollama" for local
LLM_PROVIDER=ollama

# Ollama — used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=120

# RunPod — used when LLM_PROVIDER=runpod
# Find endpoint IDs in your RunPod console under Serverless → Endpoints
RUNPOD_API_KEY=
RUNPOD_LIGHT_ENDPOINT_ID=
RUNPOD_HEAVY_ENDPOINT_ID=
RUNPOD_TIMEOUT=6000

# Azure Document Intelligence — OCR fallback for scanned PDFs and DOCXs
# Leave blank to disable OCR fallback (native extraction only)
# Endpoint format: https://<resource-name>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
